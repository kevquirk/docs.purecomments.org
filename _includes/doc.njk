---
layout: base.njk
---
<div class="layout">

    {# ── Left sidebar ── #}
    <nav id="sidebar" class="sidebar" aria-label="Documentation navigation">
        <div class="sidebar-header">
            <a href="/" class="sidebar-logo">
                <span class="logo red"><span class="pure">PURE</span><span class="service">COMMENTS</span></span>
            </a>
            <span class="sidebar-subtitle">{{ site.subtitle }}</span>
        </div>

        <div class="sidebar-nav">
            {% for section in nav %}
            <div class="nav-section">
                <span class="nav-section-label">{{ section.label }}</span>
                <ul class="nav-items">
                    {% for item in section.items %}
                    <li>
                        <a href="/{{ item.slug }}/"
                           class="nav-link{% if page.url == '/' + item.slug + '/' %} active{% endif %}">
                            {{ item.label }}
                        </a>
                    </li>
                    {% endfor %}
                </ul>
            </div>
            {% endfor %}
        </div>
    </nav>

    {# ── Main wrapper ── #}
    <div class="main-wrapper">

        {# ── Top bar ── #}
        <header class="topbar">
            <button id="sidebar-toggle" aria-label="Toggle sidebar" aria-expanded="false">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <line x1="3" y1="12" x2="21" y2="12"/>
                    <line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>

            <button id="search-btn" class="search-trigger" aria-label="Search documentation">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                </svg>
                <span class="search-placeholder">Search...</span>
                <kbd class="search-kbd">CTRL+K</kbd>
            </button>

            <div class="topbar-actions">
                <a href="/changelog/" class="topbar-link" aria-label="Changelog">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="5" cy="6" r="3"/><path d="M5 9v12"/><path d="m15 9-3-3 3-3"/><path d="M12 6h5a2 2 0 0 1 2 2v3"/><path d="M19 15v6"/><path d="M22 18h-6"/>
                    </svg>
                    <span class="topbar-link-label">Changelog</span>
                </a>
                <a href="{{ site.sourceCodeUrl }}" target="_blank" rel="noopener" class="topbar-link" aria-label="GitHub">
                    <svg width="18" height="18" viewBox="0 0 512 512" fill="currentColor">
                        <path d="M256.004 6.321c-141.369 0-256.004 114.609-256.004 255.999 0 113.107 73.352 209.066 175.068 242.918 12.793 2.369 17.496-5.555 17.496-12.316 0-6.102-0.24-26.271-0.348-47.662-71.224 15.488-86.252-30.205-86.252-30.205-11.641-29.588-28.424-37.458-28.424-37.458-23.226-15.889 1.755-15.562 1.755-15.562 25.7 1.805 39.238 26.383 39.238 26.383 22.836 39.135 59.888 27.82 74.502 21.279 2.294-16.543 8.926-27.84 16.253-34.232-56.865-6.471-116.638-28.425-116.638-126.516 0-27.949 10.002-50.787 26.38-68.714-2.658-6.45-11.427-32.486 2.476-67.75 0 0 21.503-6.876 70.42 26.245 20.418-5.674 42.318-8.518 64.077-8.617 21.751 0.099 43.668 2.943 64.128 8.617 48.867-33.122 70.328-26.245 70.328-26.245 13.936 35.264 5.175 61.3 2.518 67.75 16.41 17.928 26.347 40.766 26.347 68.714 0 98.327-59.889 119.975-116.895 126.312 9.182 7.945 17.362 23.523 17.362 47.406 0 34.254-0.298 61.822-0.298 70.254 0 6.814 4.611 14.797 17.586 12.283 101.661-33.888 174.921-129.813 174.921-242.884 0-141.39-114.617-255.999-255.996-255.999z"/>
                    </svg>
                    <span class="topbar-link-label">GitHub</span>
                </a>
                <button id="theme-toggle" aria-label="Toggle dark mode">
                    <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="5"/>
                        <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                        <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                    </svg>
                    <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                    </svg>
                </button>
            </div>
        </header>

        {# ── Content area ── #}
        <div class="content-area">
            <main class="doc-content">
                <article>
                    <div class="article-header">
                        <h1>{{ title }}</h1>
                        {% if description %}<p class="article-description">{{ description }}</p>{% endif %}
                    </div>
                    <div class="article-body">
                        {{ content | safe }}
                    </div>
                    <div class="edit-page">
                        <a href="{{ site.githubUrl }}/edit/main/{{ page.inputPath | replace('./', '') }}" target="_blank" rel="noopener" class="edit-page-link">
                            <svg width="14" height="14" viewBox="0 0 512 512" fill="currentColor">
                                <path d="M256.004 6.321c-141.369 0-256.004 114.609-256.004 255.999 0 113.107 73.352 209.066 175.068 242.918 12.793 2.369 17.496-5.555 17.496-12.316 0-6.102-0.24-26.271-0.348-47.662-71.224 15.488-86.252-30.205-86.252-30.205-11.641-29.588-28.424-37.458-28.424-37.458-23.226-15.889 1.755-15.562 1.755-15.562 25.7 1.805 39.238 26.383 39.238 26.383 22.836 39.135 59.888 27.82 74.502 21.279 2.294-16.543 8.926-27.84 16.253-34.232-56.865-6.471-116.638-28.425-116.638-126.516 0-27.949 10.002-50.787 26.38-68.714-2.658-6.45-11.427-32.486 2.476-67.75 0 0 21.503-6.876 70.42 26.245 20.418-5.674 42.318-8.518 64.077-8.617 21.751 0.099 43.668 2.943 64.128 8.617 48.867-33.122 70.328-26.245 70.328-26.245 13.936 35.264 5.175 61.3 2.518 67.75 16.41 17.928 26.347 40.766 26.347 68.714 0 98.327-59.889 119.975-116.895 126.312 9.182 7.945 17.362 23.523 17.362 47.406 0 34.254-0.298 61.822-0.298 70.254 0 6.814 4.611 14.797 17.586 12.283 101.661-33.888 174.921-129.813 174.921-242.884 0-141.39-114.617-255.999-255.996-255.999z"/>
                            </svg>
                            <span>Edit this page on GitHub</span>
                        </a>
                    </div>
                </article>

                {# Prev / Next navigation #}
                {% set allItems = [] %}
                {% for section in nav %}
                    {% for item in section.items %}
                        {% set allItems = allItems.concat([item]) %}
                    {% endfor %}
                {% endfor %}

                {% set currentIndex = -1 %}
                {% for item in allItems %}
                    {% if '/' + item.slug + '/' == page.url %}
                        {% set currentIndex = loop.index0 %}
                    {% endif %}
                {% endfor %}

                {% if currentIndex >= 0 %}
                <nav class="doc-prevnext" aria-label="Page navigation">
                    {% if currentIndex > 0 %}
                    <a href="/{{ allItems[currentIndex - 1].slug }}/" class="prevnext-btn prevnext-prev">
                        <span class="prevnext-direction">← Previous</span>
                        <span class="prevnext-title">{{ allItems[currentIndex - 1].label }}</span>
                    </a>
                    {% else %}
                    <span></span>
                    {% endif %}
                    {% if currentIndex < allItems.length - 1 %}
                    <a href="/{{ allItems[currentIndex + 1].slug }}/" class="prevnext-btn prevnext-next">
                        <span class="prevnext-direction">Next →</span>
                        <span class="prevnext-title">{{ allItems[currentIndex + 1].label }}</span>
                    </a>
                    {% endif %}
                </nav>
                {% endif %}
            </main>

            {# ── Right TOC sidebar ── #}
            <aside class="toc-sidebar" id="toc-sidebar" aria-label="On this page">
                <div class="toc-label">On this page</div>
                <nav id="toc-nav"></nav>
            </aside>
        </div>

    </div>{# /main-wrapper #}

</div>{# /layout #}

{# ── Search modal ── #}
<div id="search-modal" class="search-modal" hidden role="dialog" aria-modal="true" aria-label="Search">
    <div class="search-backdrop" id="search-backdrop"></div>
    <div class="search-dialog">
        <div class="search-input-wrap">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <input type="search" id="search-input" placeholder="Search documentation…" autocomplete="off" spellcheck="false">
            <button id="search-close" aria-label="Close search">Esc</button>
        </div>
        <ul id="search-results" class="search-results" role="listbox"></ul>
        <div id="search-empty" class="search-empty" hidden>No results found</div>
    </div>
</div>
